#version 460 core

in vec3 vNormals;
in vec2 vTexCoords;
in flat int vInstanceID;

out vec4 FragColor;

uniform sampler2DArray uAtlas;

void main() {
	FragColor = texture(uAtlas, vec3(vTexCoords, 0.0));
	//if (vInstanceID != 0) FragColor = vec4(1.0f, 0.0, 0.0, 1.0);

	//FragColor = vec4 ( float(vInstanceID) / 10.0, float(vInstanceID) / 10.0, float(vInstanceID) / 10.0, 1.0);
};